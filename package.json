{
  "name": "@openclaw/content-engine",
  "version": "0.1.0",
  "description": "AI-powered editorial pipeline: Telegram → Discourse",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
