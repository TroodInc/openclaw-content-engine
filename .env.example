# Telegram API credentials (https://my.telegram.org)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_CHANNEL=

# Saved session string (populated after first auth)
TELEGRAM_SESSION=

# OpenAI API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
ARTICLE_EXTRACTOR_TIMEOUT_MS=15000
ARTICLE_EXTRACTOR_MAX_LENGTH=50000
ARTICLE_EXTRACTOR_CA_CERT_PATH=
ARTICLE_EXTRACTOR_COOKIE=
ARTICLE_EXTRACTOR_USER_AGENT=
ARTICLE_EXTRACTOR_HEADERS_JSON=

# Discourse API
DISCOURSE_URL=https://forum.example.com
DISCOURSE_API_KEY=
DISCOURSE_USERNAME=
DISCOURSE_CATEGORY_ID=1

# PostgreSQL (requires pgvector extension)
DATABASE_URL=postgresql://localhost:5432/openclaw
